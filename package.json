{
  "name": "app-devtools",
  "version": "1.6.0",
  "description": "",
  "scripts": {
    "dev": "vite",
    "test": "vitest --ui",
    "test:run": "echo 'no tests'",
    "preview": "vite preview",
    "tsc": "tsc -p tsconfig.prod.json",
    "eslint": "eslint src --max-warnings 0",
    "lint": "pnpm eslint && pnpm tsc",
    "tsc:w": "tsc -w -p tsconfig.prod.json",
    "convert-har": "tsm scripts/filterFetchRequests.ts",
    "build": "pnpm test:run && pnpm lint && pnpm build:no-test",
    "build:no-test": "vite build && tsup --dts-only",
    "pre-publish": "pnpm run build"
  },
  "packageManager": "pnpm@11.10.0",
  "license": "MIT",
  "author": "Lucas Santos",
  "repository": "github:lucasols/app-devtools",
  "type": "module",
  "main": "./dist/main.js",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "dependencies": {
    "@ls-stack/utils": "^3.77.0",
    "@lucasols/utils": "^4.31.0",
    "dayjs": "^1.11.21",
    "immer": "^10.2.0",
    "klona": "^2.0.6",
    "nanoid": "^5.1.16",
    "regexparam": "^3.0.0",
    "solid-js": "^1.9.14",
    "solid-styled-components": "^0.28.5",
    "tinykeys": "^2.1.0"
  },
  "volta": {
    "node": "24.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@lucasols/eslint-plugin-extended-lint": "^1.6.0",
    "@types/node": "^24.13.2",
    "@vitest/ui": "^4.1.10",
    "babel-plugin-solid-labels": "^0.15.1",
    "eslint": "^9.39.4",
    "happy-dom": "^20.10.6",
    "oslu": "^0.22.1",
    "tsm": "^2.3.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "typescript-styled-plugin": "^0.18.3",
    "vite": "^8.1.3",
